<header class="sticky-top py-3" style="background: var(--header-bg); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border-bottom: 1px solid var(--border-color); z-index: 1020;">
  <nav class="navbar navbar-expand-lg navbar-light bg-transparent py-0">
    <div class="container">
      <a class="navbar-brand fw-bold fs-3 d-flex align-items-center gap-2" href="/" style="letter-spacing: -0.03em;">
        <span class="gradient-text"><%= siteName %></span>
      </a>
      <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#raiseToolNav" aria-controls="raiseToolNav" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="raiseToolNav">
        <div class="navbar-nav me-auto mb-2 mb-lg-0 ms-lg-4 gap-1">
          <a class="nav-link fw-semibold px-3 py-2 rounded-3" href="/categories">Categories</a>
          <a class="nav-link fw-semibold px-3 py-2 rounded-3" href="/about">About</a>
          <a class="nav-link fw-semibold px-3 py-2 rounded-3" href="/contact">Contact</a>
        </div>
        <div class="ms-auto d-flex gap-2 align-items-center mt-3 mt-lg-0">
          <button id="pwa-install-btn" class="btn btn-outline-primary px-3 py-2 d-none">📥 Install App</button>
          <button id="theme-toggle-btn" class="btn btn-outline-secondary d-flex align-items-center justify-content-center p-0" style="width: 38px; height: 38px; border-radius: 50%; font-size: 1.1rem;" title="Toggle Dark/Light Mode" aria-label="Toggle Theme">🌓</button>
          <a href="/" class="btn btn-link text-decoration-none text-secondary fw-semibold">Home</a>
          <a href="/workspace" class="btn btn-primary px-4 py-2 shadow-sm">My Workspace</a>
        </div>
      </div>
    </div>
  </nav>
</header>

