    <div class="d-flex flex-column flex-md-row justify-content-between align-items-center gap-2 small text-secondary">
      <p class="mb-0">&copy; <%= new Date().getFullYear() %> <%= siteName %>. All rights reserved. Professional multi-utility platform.</p>
      <div class="d-flex gap-2">
        <span class="badge bg-light text-primary border">Version 1.2.0</span>
        <span class="badge bg-light text-success border">100% Secure</span>
      </div>
