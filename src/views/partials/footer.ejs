<footer class="pt-5 pb-4 mt-auto" style="background: var(--header-bg); border-top: 1px solid var(--border-color); z-index: 1020;">
  <div class="container">
    <div class="row g-4 mb-4">
      <!-- Brand & About -->
      <div class="col-12 col-md-4">
        <h5 class="fw-bold text-dark mb-3"><%= siteName %></h5>
        <p class="small text-secondary mb-0" style="line-height: 1.6;">
          RaiseTool is a premium, developer-first online utility workspace. We provide safe, client-server isolated tools to clean, format, transform, and optimize media files and text data.
        </p>
      </div>

      <!-- Quick Nav -->
      <div class="col-6 col-md-2">
        <h6 class="fw-bold text-dark small text-uppercase mb-3" style="letter-spacing: 0.05em;">Explore</h6>
        <ul class="list-unstyled d-flex flex-column gap-2 small">
          <li><a href="/" class="text-secondary text-decoration-none hover-indigo">Home</a></li>
          <li><a href="/categories" class="text-secondary text-decoration-none hover-indigo">Categories</a></li>
          <li><a href="/workspace" class="text-secondary text-decoration-none hover-indigo">My Workspace</a></li>
          <li><a href="/about" class="text-secondary text-decoration-none hover-indigo">About Us</a></li>
        </ul>
      </div>

      <!-- Policies Nav -->
      <div class="col-6 col-md-3">
        <h6 class="fw-bold text-dark small text-uppercase mb-3" style="letter-spacing: 0.05em;">Legal & Privacy</h6>
        <ul class="list-unstyled d-flex flex-column gap-2 small">
          <li><a href="/privacy" class="text-secondary text-decoration-none hover-indigo">Privacy Policy</a></li>
          <li><a href="/terms" class="text-secondary text-decoration-none hover-indigo">Terms of Service</a></li>
          <li><a href="/cookies" class="text-secondary text-decoration-none hover-indigo">Cookie Policy</a></li>
          <li><a href="/disclaimer" class="text-secondary text-decoration-none hover-indigo">DMCA Disclaimer</a></li>
          <li><a href="/data-safety" class="text-secondary text-decoration-none hover-indigo">Data Safety & Lifecycle</a></li>
        </ul>
