<!DOCTYPE html>
<html lang="en">

<head>
  <% const resolvedSiteName=typeof siteName !=='undefined' ? siteName : 'RaiseTool' ; %>
    <% const resolvedSiteUrl=typeof siteUrl !=='undefined' ? siteUrl : '' ; %>
      <% const resolvedCurrentPath=typeof currentPath !=='undefined' ? currentPath : '/' ; %>
        <% const canonicalUrl=resolvedSiteUrl ? `${resolvedSiteUrl}${resolvedCurrentPath}` : '/' ; %>
          <meta charset="utf-8">
          <meta name="viewport" content="width=device-width, initial-scale=1">
          <title>
            <%= typeof title !=='undefined' && title ? title : resolvedSiteName %>
          </title>
          <meta name="description"
            content="RaiseTool is a clean, production-oriented utility platform for document, media, developer, student, business, and everyday tools.">
          <meta name="theme-color" content="#0284c7">
          <link rel="manifest" href="/manifest.json">
          <link rel="canonical" href="<%= canonicalUrl %>">
          <link rel="stylesheet" href="/vendor/bootstrap.min.css">
          <link rel="stylesheet" href="/css/app.css">
</head>

<body class="d-flex flex-column min-vh-100" data-pwa-cache="<%= systemSettings.pwaOfflineCache !== false %>">
  <%- include('../partials/header') %>
    <main class="flex-grow-1">
      <%- body %>
    </main>
    <%- include('../partials/footer') %>
      <script src="/vendor/bootstrap.bundle.min.js" defer></script>
      
      <!-- Mobile Bottom Control Center (iOS Liquid Glass Navbar) -->
      <div class="mobile-bottom-nav d-lg-none d-flex justify-content-around align-items-center">
        <a href="/" class="nav-item" data-path="/">
          <div class="nav-icon">🏠</div>
          <div class="nav-label">Home</div>
        </a>
        <a href="/categories" class="nav-item" data-path="/categories">
          <div class="nav-icon">📁</div>
          <div class="nav-label">Categories</div>
        </a>
        <a href="/workspace" class="nav-item" data-path="/workspace">
          <div class="nav-icon">💼</div>
          <div class="nav-label">Workspace</div>
        </a>
        <a href="/about" class="nav-item" data-path="/about">
          <div class="nav-icon">💡</div>
          <div class="nav-label">About</div>
        </a>
      </div>

      <script>
        document.addEventListener('DOMContentLoaded', () => {
          const currentPath = window.location.pathname;
          const navItems = document.querySelectorAll('.mobile-bottom-nav .nav-item');
          navItems.forEach(item => {
            const itemPath = item.getAttribute('data-path');
            if (currentPath === itemPath || (itemPath !== '/' && currentPath.startsWith(itemPath))) {
              item.classList.add('active');
            }
          });

          // Service Worker Registration
          const pwaCacheEnabled = document.body.getAttribute('data-pwa-cache') !== 'false';
          if ('serviceWorker' in navigator && pwaCacheEnabled) {
            const pwaVersion = '<%= systemSettings.pwaCacheVersion || 1 %>';
            
            // Reload page on controller change (forces fresh UI when SW updates)
            let refreshing = false;
            navigator.serviceWorker.addEventListener('controllerchange', () => {
              if (!refreshing) {
                refreshing = true;
                window.location.reload();
              }
            });

            navigator.serviceWorker.register('/service-worker.js?v=' + pwaVersion)
              .then((reg) => {
                console.log('[PWA] Service Worker registered scope:', reg.scope);
                // Check if update is waiting
                if (reg.waiting) {
                  console.log('[PWA] Service Worker update is waiting.');
                  reg.waiting.postMessage({ type: 'SKIP_WAITING' });
                }
              })
              .catch((err) => console.error('[PWA] Service Worker registration failed:', err));
          }

          // Custom Install Prompt logic
          let deferredPrompt;
          const installBtn = document.getElementById('pwa-install-btn');

          window.addEventListener('beforeinstallprompt', (e) => {
            e.preventDefault();
            deferredPrompt = e;
            if (installBtn) {
              installBtn.classList.remove('d-none');
              installBtn.style.display = 'inline-flex';
            }
          });

          if (installBtn) {
            installBtn.addEventListener('click', async () => {
              if (!deferredPrompt) return;
              deferredPrompt.prompt();
              const { outcome } = await deferredPrompt.userChoice;
              console.log('[PWA] Install choice outcome:', outcome);
              deferredPrompt = null;
              installBtn.classList.add('d-none');
              installBtn.style.display = 'none';
            });
          }

          window.addEventListener('appinstalled', () => {
            console.log('[PWA] RaiseTool app installed successfully.');
            if (installBtn) {
              installBtn.classList.add('d-none');
              installBtn.style.display = 'none';
            }
          });
        });
      </script>
</body>

</html>