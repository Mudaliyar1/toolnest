<!DOCTYPE html>
<html lang="en" class="dark-theme">

<head>
  <% const resolvedSiteName=typeof siteName !=='undefined' ? siteName : 'RaiseTool' ; %>
    <% const resolvedSiteUrl=typeof siteUrl !=='undefined' ? siteUrl : '' ; %>
      <% const resolvedCurrentPath=typeof currentPath !=='undefined' ? currentPath : '/' ; %>
        <% const canonicalUrl=resolvedSiteUrl ? `${resolvedSiteUrl}${resolvedCurrentPath}` : '/' ; %>
          <meta charset="utf-8">
          <meta name="viewport" content="width=device-width, initial-scale=1">
          <title>
            <%= typeof title !=='undefined' && title ? title : resolvedSiteName %>
          </title>
          <meta name="description"
            content="RaiseTool is a clean, production-oriented utility platform for document, media, developer, student, business, and everyday tools.">
          <meta name="theme-color" content="#2563eb">
          <link rel="manifest"
            href="/manifest.json?v=<%= typeof systemSettings !== 'undefined' && systemSettings && systemSettings.pwaCacheVersion || 1 %>">
          <link rel="canonical" href="<%= canonicalUrl %>">
          <link rel="stylesheet" href="/vendor/bootstrap.min.css">
          <link rel="stylesheet"
            href="/css/app.css?v=<%= typeof systemSettings !== 'undefined' && systemSettings && systemSettings.pwaCacheVersion || 1 %>">
          <script>
            (function () {
              const savedTheme = localStorage.getItem('theme');
              if (savedTheme === 'light') {
                document.documentElement.classList.remove('dark-theme');
              }
            })();
          </script>
</head>

<body class="d-flex flex-column min-vh-100"
  data-pwa-cache="<%= (typeof systemSettings !== 'undefined' && systemSettings && systemSettings.pwaOfflineCache !== false) %>">
  <!-- YouTube-Style PWA Splash Screen -->
  <div id="pwa-splash-screen">
    <div class="splash-content">
      <div class="splash-logo">🛠️</div>
      <div class="splash-brand">RaiseTool</div>
      <div class="splash-spinner"></div>
    </div>
  </div>
  <%- include('../partials/header') %>
    <main class="flex-grow-1">
      <%- body %>
    </main>
    <%- include('../partials/footer') %>
      <script src="/vendor/bootstrap.bundle.min.js" defer></script>

      <!-- Mobile Bottom Control Center (iOS Liquid Glass Navbar) -->
      <div class="mobile-bottom-nav d-lg-none d-flex justify-content-around align-items-center">
        <a href="/" class="nav-item" data-path="/">
          <div class="nav-icon">
            <svg class="bi" viewBox="0 0 16 16" fill="currentColor">
              <path
                d="M8.707 1.5a1 1 0 0 0-1.414 0L.646 8.146a.5.5 0 0 0 .708.708L2 8.207V13.5A1.5 1.5 0 0 0 3.5 15h9a1.5 1.5 0 0 0 1.5-1.5V8.207l.646.647a.5.5 0 0 0 .708-.708L13 5.793V2.5a.5.5 0 0 0-.5-.5h-1a.5.5 0 0 0-.5.5v1.293L8.707 1.5Z" />
              <path d="M3 10.5a.5.5 0 0 1 .5-.5h9a.5.5 0 0 1 0 1h-9a.5.5 0 0 1-.5-.5Z" />
            </svg>
          </div>
          <div class="nav-label">Home</div>
        </a>
        <a href="/categories" class="nav-item" data-path="/categories">
          <div class="nav-icon">
            <svg class="bi" viewBox="0 0 16 16" fill="currentColor">
              <path
                d="M1 2.5A1.5 1.5 0 0 1 2.5 1h3A1.5 1.5 0 0 1 7 2.5v3A1.5 1.5 0 0 1 5.5 7h-3A1.5 1.5 0 0 1 1 5.5v-3zM2.5 2a.5.5 0 0 0-.5.5v3a.5.5 0 0 0 .5.5h3a.5.5 0 0 0 .5-.5v-3a.5.5 0 0 0-.5-.5h-3zm6.5.5A1.5 1.5 0 0 1 10.5 1h3A1.5 1.5 0 0 1 15 2.5v3A1.5 1.5 0 0 1 13.5 7h-3A1.5 1.5 0 0 1 9 5.5v-3zm1.5-.5a.5.5 0 0 0-.5.5v3a.5.5 0 0 0 .5.5h3a.5.5 0 0 0 .5-.5v-3a.5.5 0 0 0-.5-.5h-3zM1 10.5A1.5 1.5 0 0 1 2.5 9h3A1.5 1.5 0 0 1 7 10.5v3A1.5 1.5 0 0 1 5.5 15h-3A1.5 1.5 0 0 1 1 13.5v-3zm1.5-.5a.5.5 0 0 0-.5.5v3a.5.5 0 0 0 .5.5h3a.5.5 0 0 0 .5-.5v-3a.5.5 0 0 0-.5-.5h-3zm6.5.5A1.5 1.5 0 0 1 10.5 9h3a1.5 1.5 0 0 1 1.5 1.5v3a1.5 1.5 0 0 1-1.5 1.5h-3A1.5 1.5 0 0 1 9 13.5v-3zm1.5-.5a.5.5 0 0 0-.5.5v3a.5.5 0 0 0 .5.5h3a.5.5 0 0 0 .5-.5v-3a.5.5 0 0 0-.5-.5h-3z" />
            </svg>
          </div>
          <div class="nav-label">Categories</div>
        </a>
        <a href="/workspace" class="nav-item" data-path="/workspace">
          <div class="nav-icon">
            <svg class="bi" viewBox="0 0 16 16" fill="currentColor">
              <path
                d="M6.5 1A1.5 1.5 0 0 0 5 2.5V3H1.5A1.5 1.5 0 0 0 0 4.5v8A1.5 1.5 0 0 0 1.5 14h13a1.5 1.5 0 0 0 1.5-1.5v-8A1.5 1.5 0 0 0 14.5 3H11v-.5A1.5 1.5 0 0 0 9.5 1h-3zm0 1h3a.5.5 0 0 1 .5.5V3H6v-.5a.5.5 0 0 1 .5-.5zm1.886 6.914L15 7.151V12.5a.5.5 0 0 1-.5.5h-13a.5.5 0 0 1-.5-.5V7.15l6.614 1.764a1.5 1.5 0 0 0 .772 0zM1.5 4h13a.5.5 0 0 1 .5.5v1.616L8.129 7.948a.5.5 0 0 1-.258 0L1 6.116V4.5a.5.5 0 0 1 .5-.5z" />
            </svg>
          </div>
          <div class="nav-label">Workspace</div>
        </a>
        <a href="/about" class="nav-item" data-path="/about">
          <div class="nav-icon">
            <svg class="bi" viewBox="0 0 16 16" fill="currentColor">
              <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z" />
              <path
                d="m8.93 6.588-2.29.287-.082.38.45.083c.294.07.352.176.288.469l-.738 3.468c-.194.897.105 1.319.808 1.319.545 0 1.178-.252 1.465-.598l.088-.416c-.2.176-.492.246-.686.246-.275 0-.375-.193-.304-.533L8.93 6.588zM8 5.5a1 1 0 1 0 0-2 1 1 0 0 0 0 2z" />
            </svg>
          </div>
          <div class="nav-label">About</div>
        </a>
      </div>

      <script>
        document.addEventListener('DOMContentLoaded', () => {
          // PWA Single Page Application (SPA) No-Refresh Router
          function isRunningAsPWA() {
            return window.matchMedia('(display-mode: standalone)').matches ||
              window.navigator.standalone === true ||
              document.referrer.includes('android-app://');
          }

          // YouTube-Style PWA Splash Screen Controller
          if (isRunningAsPWA() && !sessionStorage.getItem('pwa-splash-shown')) {
            setTimeout(() => {
              const splash = document.getElementById('pwa-splash-screen');
              if (splash) {
                splash.classList.add('fade-out');
                sessionStorage.setItem('pwa-splash-shown', 'true');
                setTimeout(() => splash.remove(), 600);
              }
            }, 1600);
          } else {
            const splash = document.getElementById('pwa-splash-screen');
            if (splash) splash.remove();
          }

          // Dynamically lock orientation to portrait in PWA mode if supported by the device browser
          if (isRunningAsPWA() && window.screen && window.screen.orientation && typeof window.screen.orientation.lock === 'function') {
            window.screen.orientation.lock('portrait-primary').catch((err) => {
              console.warn('[PWA] Dynamic screen orientation lock failed:', err);
            });
          }

          if (isRunningAsPWA()) {
            console.log('[PWA] Standalone mode detected. Initializing SPA Navigation Router.');

            // Helper to show/hide dynamic top progress line
            function showPWALoader() {
              let loader = document.getElementById('pwa-nav-loader');
              if (!loader) {
                loader = document.createElement('div');
                loader.id = 'pwa-nav-loader';
                loader.style.cssText = 'position:fixed;top:0;left:0;height:3px;width:0;background:#2563eb;box-shadow:0 0 10px rgba(37,99,235,0.5);z-index:99999;transition:width 0.4s cubic-bezier(0.1,0.8,0.1,1);';
                document.body.appendChild(loader);
              }
              loader.style.width = '0%';
              loader.style.opacity = '1';
              loader.offsetHeight; // force reflow
              loader.style.width = '70%';
            }

            function hidePWALoader() {
              const loader = document.getElementById('pwa-nav-loader');
              if (loader) {
                loader.style.width = '100%';
                setTimeout(() => {
                  loader.style.opacity = '0';
                  setTimeout(() => { loader.style.width = '0%'; }, 300);
                }, 200);
              }
            }

            // Extract and re-execute main view scripts
            function reExecuteMainScripts(container) {
              const scripts = container.querySelectorAll('script');
              scripts.forEach((oldScript) => {
                const newScript = document.createElement('script');
                Array.from(oldScript.attributes).forEach(attr => newScript.setAttribute(attr.name, attr.value));
                newScript.appendChild(document.createTextNode(oldScript.innerHTML));
                oldScript.parentNode.replaceChild(newScript, oldScript);
              });
            }

            function updateActiveNavLinks(path) {
              const navItems = document.querySelectorAll('.mobile-bottom-nav .nav-item');
              navItems.forEach(item => {
                const itemPath = item.getAttribute('data-path');
                if (path === itemPath || (itemPath !== '/' && path.startsWith(itemPath))) {
                  item.classList.add('active');
                } else {
                  item.classList.remove('active');
                }
              });

              const headerLinks = document.querySelectorAll('.navbar-nav .nav-link');
              headerLinks.forEach(link => {
                try {
                  const linkPath = new URL(link.href, window.location.origin).pathname;
                  if (path === linkPath) {
                    link.classList.add('active');
                  } else {
                    link.classList.remove('active');
                  }
                } catch (e) { }
              });
            }

            async function navigateToPage(urlPath, pushState = true) {
              try {
                showPWALoader();
                const response = await fetch(urlPath);
                if (!response.ok) throw new Error('Network response not ok');
                const html = await response.text();
                const parser = new DOMParser();
                const doc = parser.parseFromString(html, 'text/html');

                const currentMain = document.querySelector('main');
                const newMain = doc.querySelector('main');
                if (currentMain && newMain) {
                  currentMain.innerHTML = newMain.innerHTML;
                  reExecuteMainScripts(currentMain);
                }

                document.title = doc.title;
                if (pushState) {
                  history.pushState({ path: urlPath }, doc.title, urlPath);
                }
                updateActiveNavLinks(urlPath);
                window.scrollTo({ top: 0, behavior: 'instant' });
                hidePWALoader();
              } catch (err) {
                console.warn('[PWA Router] SPA navigation failed. Falling back to reload:', err);
                window.location.href = urlPath;
              }
            }

            // Intercept internal link navigation clicks
            document.addEventListener('click', (e) => {
              const link = e.target.closest('a');
              if (!link) return;

              const href = link.getAttribute('href');
              if (!href) return;

              // Handle hash link scrolling smoothly within dynamic layouts
              if (href.startsWith('#')) {
                const target = document.querySelector(href);
                if (target) {
                  e.preventDefault();
                  target.scrollIntoView({ behavior: 'smooth' });
                }
                return;
              }

              if (href.startsWith('javascript:') || link.getAttribute('target') === '_blank') {
                return;
              }

              const url = new URL(link.href, window.location.origin);
              if (url.origin !== window.location.origin) return;

              // Skip administrative or download links
              if (link.hasAttribute('download') ||
                url.pathname.startsWith('/admin') ||
                (url.pathname.startsWith('/workspace/files/') && url.pathname.endsWith('/download'))) {
                return;
              }

              e.preventDefault();
              navigateToPage(url.pathname + url.search);
            });

            // Popstate handling
            window.addEventListener('popstate', () => {
              navigateToPage(window.location.pathname + window.location.search, false);
            });
          }

          const currentPath = window.location.pathname;
          const navItems = document.querySelectorAll('.mobile-bottom-nav .nav-item');
          navItems.forEach(item => {
            const itemPath = item.getAttribute('data-path');
            if (currentPath === itemPath || (itemPath !== '/' && currentPath.startsWith(itemPath))) {
              item.classList.add('active');
            }
          });

          // Service Worker Registration
          const pwaCacheEnabled = document.body.getAttribute('data-pwa-cache') !== 'false';
          if ('serviceWorker' in navigator && pwaCacheEnabled) {
            const pwaVersion = '<%= typeof systemSettings !== "undefined" && systemSettings && systemSettings.pwaCacheVersion || 1 %>';

            // Reload page on controller change (forces fresh UI when SW updates)
            let refreshing = false;
            navigator.serviceWorker.addEventListener('controllerchange', () => {
              if (!refreshing) {
                refreshing = true;
                window.location.reload();
              }
            });

            navigator.serviceWorker.register('/service-worker.js?v=' + pwaVersion)
              .then((reg) => {
                console.log('[PWA] Service Worker registered scope:', reg.scope);
                // Check if update is waiting
                if (reg.waiting) {
                  console.log('[PWA] Service Worker update is waiting.');
                  reg.waiting.postMessage({ type: 'SKIP_WAITING' });
                }
              })
              .catch((err) => console.error('[PWA] Service Worker registration failed:', err));
          }

          // Custom Install Prompt logic
          let deferredPrompt;
          const installBtn = document.getElementById('pwa-install-btn');

          window.addEventListener('beforeinstallprompt', (e) => {
            e.preventDefault();
            deferredPrompt = e;
            if (installBtn) {
              installBtn.classList.remove('d-none');
              installBtn.style.display = 'inline-flex';
            }
          });

          if (installBtn) {
            installBtn.addEventListener('click', async () => {
              if (!deferredPrompt) return;
              deferredPrompt.prompt();
              const { outcome } = await deferredPrompt.userChoice;
              console.log('[PWA] Install choice outcome:', outcome);
              deferredPrompt = null;
              installBtn.classList.add('d-none');
              installBtn.style.display = 'none';
            });
          }

          window.addEventListener('appinstalled', () => {
            console.log('[PWA] RaiseTool app installed successfully.');
            if (installBtn) {
              installBtn.classList.add('d-none');
              installBtn.style.display = 'none';
            }
          });

          // Theme Toggle Event Listener
          const themeToggle = document.getElementById('theme-toggle-btn');
          if (themeToggle) {
            function updateThemeToggleIcon(isDark) {
              themeToggle.innerHTML = isDark ? '☀️' : '🌙';
              themeToggle.title = isDark ? 'Switch to Light Mode' : 'Switch to Dark Mode';
            }

            // Initialize icon state based on active class
            updateThemeToggleIcon(document.documentElement.classList.contains('dark-theme'));

            themeToggle.addEventListener('click', () => {
              const isDark = document.documentElement.classList.toggle('dark-theme');
              localStorage.setItem('theme', isDark ? 'dark' : 'light');
              updateThemeToggleIcon(isDark);
            });
          }
        });
      </script>
</body>

</html>