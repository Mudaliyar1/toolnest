<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= typeof title !== 'undefined' && title ? title : 'Admin Panel | RaiseTool' %></title>
  <meta name="theme-color" content="#0f172a">
  <link rel="stylesheet" href="/vendor/bootstrap.min.css">
  <link rel="stylesheet" href="/css/app.css">
  <script>
    (function() {
      const savedTheme = localStorage.getItem('theme');
      if (savedTheme !== 'light') {
        document.documentElement.classList.add('dark-theme');
      }
    })();
  </script>
  <style>
    :root {
      --sidebar-width: 260px;
      --sidebar-bg: #0f172a;
      --sidebar-color: #94a3b8;
      --sidebar-active-bg: #1e293b;
      --sidebar-active-color: #f8fafc;
    }
    body {
      background-color: var(--bg-main);
      color: var(--text-main);
      min-height: 100vh;
      font-family: 'Inter', sans-serif;
    }
    .admin-wrapper {
      display: flex;
      width: 100%;
      align-items: stretch;
    }
    .admin-sidebar {
      width: var(--sidebar-width);
      background: var(--sidebar-bg);
      color: var(--sidebar-color);
      min-height: 100vh;
      position: fixed;
      top: 0;
      left: 0;
      z-index: 1000;
      transition: all 0.3s ease;
      display: flex;
      flex-direction: column;
      border-right: 1px solid #1e293b;
    }
    .admin-sidebar .sidebar-header {
      padding: 1.5rem 1.25rem;
      border-bottom: 1px solid #1e293b;
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .admin-sidebar .nav-link {
      color: var(--sidebar-color);
      padding: 0.8rem 1.25rem;
      display: flex;
      align-items: center;
      gap: 12px;
      font-size: 0.95rem;
      font-weight: 500;
      border-left: 3px solid transparent;
      transition: all 0.2s ease;
      text-decoration: none;
    }
    .admin-sidebar .nav-link:hover {
      background: var(--sidebar-active-bg);
      color: var(--sidebar-active-color);
    }
    .admin-sidebar .nav-link.active {
      background: var(--sidebar-active-bg);
      color: var(--sidebar-active-color);
      border-left-color: #0ea5e9;
    }
    .admin-content {
      flex: 1;
      margin-left: var(--sidebar-width);
      padding: 2.5rem;
      min-height: 100vh;
      transition: all 0.3s ease;
      min-width: 0;
    }
    .admin-mobile-header {
      display: none;
      background: #ffffff;
      border-bottom: 1px solid #e2e8f0;
      padding: 1rem 1.5rem;
      align-items: center;
      justify-content: space-between;
      position: sticky;
      top: 0;
      z-index: 999;
    }
    
    @media (max-width: 991.98px) {
      .admin-sidebar {
        transform: translateX(-100%);
        margin-left: 0 !important;
      }
      .admin-sidebar.show {
        transform: translateX(0);
      }
      .admin-content {
        margin-left: 0;
        padding: 1.25rem;
        width: 100%;
        overflow-x: hidden;
      }
      .admin-mobile-header {
        display: flex;
      }
    }

    /* Modern mobile overlay backdrop */
    .sidebar-backdrop {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      width: 100vw;
      height: 100vh;
      background: rgba(15, 23, 42, 0.5);
      backdrop-filter: blur(3px);
      -webkit-backdrop-filter: blur(3px);
      z-index: 998;
      transition: opacity 0.25s ease;
    }
    .sidebar-backdrop.show {
      display: block;
    }
    
    html.dark-theme .admin-mobile-header {
      background: var(--bg-card);
      border-bottom-color: var(--border-color);
    }
    html.dark-theme .admin-mobile-header .text-dark {
      color: var(--text-dark) !important;
    }
  </style>
</head>
<body>
  <div class="sidebar-backdrop" id="sidebar-backdrop"></div>

  <div class="admin-mobile-header">
    <div class="d-flex align-items-center gap-2">
      <span class="fs-4">🛠️</span>
      <span class="fw-bold text-dark">RaiseTool Admin</span>
    </div>
    <button class="btn btn-outline-secondary btn-sm" id="sidebar-toggle-btn">
      ☰ Menu
    </button>
  </div>

  <div class="admin-wrapper">
    <!-- Sidebar -->
    <aside class="admin-sidebar" id="admin-sidebar">
      <div class="sidebar-header">
        <span class="fs-3">🛠️</span>
        <div>
          <div class="fw-bold text-white lh-sm">RaiseTool</div>
          <small class="text-secondary">Control Center</small>
        </div>
      </div>
      
      <div class="flex-grow-1 py-3">
        <nav class="nav flex-column">
          <a href="<%= adminAccessPath %>/dashboard" class="nav-link <%= currentPath === adminAccessPath + '/dashboard' ? 'active' : '' %>">
            📊 System Overview
          </a>
          <a href="<%= adminAccessPath %>/stats" class="nav-link <%= currentPath === adminAccessPath + '/stats' ? 'active' : '' %>">
            📈 Detailed Statistics
          </a>
          <a href="<%= adminAccessPath %>/performance" class="nav-link <%= currentPath === adminAccessPath + '/performance' ? 'active' : '' %>">
            💻 Server Performance
          </a>
          <a href="<%= adminAccessPath %>/processing" class="nav-link <%= currentPath === adminAccessPath + '/processing' ? 'active' : '' %>">
            ⚙️ Processing & PWA
          </a>
        </nav>
      </div>

      <div class="p-3 border-top border-secondary">
        <div class="d-flex flex-column gap-2">
          <button id="admin-theme-toggle-btn" class="btn btn-outline-light btn-sm w-100 py-2 mb-1" style="border-radius: 50rem; font-weight: 600;">
            🌓 Toggle Theme Mode
          </button>
          <a href="/" class="btn btn-outline-light btn-sm w-100 py-2">
            🏠 Back to Site
          </a>
          <form method="post" action="<%= adminAccessPath %>/logout" class="w-100">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button type="submit" class="btn btn-danger btn-sm w-100 py-2">
              🚪 Sign Out
            </button>
          </form>
        </div>
      </div>
    </aside>

    <!-- Main Content -->
    <main class="admin-content">
      <%- body %>
    </main>
  </div>

  <script src="/vendor/bootstrap.bundle.min.js"></script>
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const toggleBtn = document.getElementById('sidebar-toggle-btn');
      const sidebar = document.getElementById('admin-sidebar');
      const backdrop = document.getElementById('sidebar-backdrop');

      function showSidebar() {
        sidebar.classList.add('show');
        if (backdrop) backdrop.classList.add('show');
      }

      function hideSidebar() {
        sidebar.classList.remove('show');
        if (backdrop) backdrop.classList.remove('show');
      }

      if (toggleBtn && sidebar) {
        toggleBtn.addEventListener('click', (e) => {
          e.stopPropagation();
          if (sidebar.classList.contains('show')) {
            hideSidebar();
          } else {
            showSidebar();
          }
        });
      }

      if (backdrop) {
        backdrop.addEventListener('click', () => {
          hideSidebar();
        });
      }

      document.body.addEventListener('click', (e) => {
        if (sidebar && !sidebar.contains(e.target) && e.target !== toggleBtn) {
          hideSidebar();
        }
      });

      // Sidebar Theme Toggle Event Listener
      const adminThemeToggle = document.getElementById('admin-theme-toggle-btn');
      if (adminThemeToggle) {
        adminThemeToggle.addEventListener('click', () => {
          const isDark = document.documentElement.classList.toggle('dark-theme');
          localStorage.setItem('theme', isDark ? 'dark' : 'light');
        });
      }
    });
  </script>
</body>
</html>
