<% layout('layouts/main') -%>
<section class="container py-5 py-lg-6 text-center">
  <div class="row justify-content-center">
    <div class="col-lg-6">
      <div class="card shadow-sm border-0 glass-panel">
        <div class="card-body p-5">
          <div class="display-1 text-primary mb-3">⏳</div>
          <h1 class="display-6 fw-bold mb-3 text-dark">Too Many Requests</h1>
          <p class="text-secondary mb-4">
            Whoa there, speed racer! You've sent too many requests in a short period. Please take a brief breath and let our servers cool down for a few moments.
          </p>
          <div class="alert alert-info border-0 rounded-3 small mb-4 py-2 px-3 text-start d-flex align-items-center gap-2">
            <span>ℹ</span>
            <span>This temporary rate limit protects our free community utilities from automated spam, D-DoS, and heavy scrapers.</span>
          </div>
          <div class="d-flex flex-column flex-sm-row justify-content-center gap-2">
            <button onclick="window.location.reload();" class="btn btn-primary px-4 py-2">
              🔄 Try Again Now
            </button>
            <a href="/" class="btn btn-outline-secondary px-4 py-2">
              🏠 Go back Home
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
