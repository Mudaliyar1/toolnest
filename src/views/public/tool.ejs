        <div class="modal-content border-0 shadow-lg">
          <div class="modal-header border-0 pb-0">
            <h5 class="modal-title fw-bold text-dark w-100 text-center" id="browserProcessingModalLabel">Browser
              Processing</h5>
            <button type="button" class="btn-close d-none" id="btn-close-browser-modal" data-bs-dismiss="modal"
              aria-label="Close"></button>
          </div>
          <div class="modal-body text-center px-4 py-5 d-flex flex-column align-items-center justify-content-center">
            <!-- Progress Spinner / Micro-animation -->
            <div id="browser-modal-spinner" class="mb-4">
              <div class="spinner-border text-primary" role="status"
                style="width: 4rem; height: 4rem; border-width: 0.35em;">
