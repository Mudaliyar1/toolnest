                                                              download the file below.</div>
                                                          </div>
                                                          <div class="d-grid gap-2">
                                                            <% resultRecords.forEach((file)=> { %>
                                                              <div
                                                                class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2 bg-white border rounded-3 p-3">
                                                                <div class="fw-medium">
                                                                  <%= file.processedName %>
                                                                </div>
                                                                <a href="/workspace/files/<%= file._id %>/download"
                                                                  class="btn btn-outline-primary btn-sm"
                                                                  download="<%= file.processedName %>">Download</a>
                                                              </div>
                                                              <% }) %>
                                                          </div>
                                                          <% } %>
                                                    </div>
                                                  </div>
                                                  <% } %>
                                                    <% } %>

                                                      <!-- Professional About / FAQ Section at the bottom of card -->
