                                                    <%= result.title %>
                                                  </div>
                                                  <div class="small">
                                                    <%= result.content %>
                                                  </div>
                                                </div>
                                                <% } else { %>
                                                  <div class="card bg-light border-0 mt-4">
                                                    <div class="card-body">
                                                      <h2 class="h5 fw-semibold mb-3">
                                                        <%= result.title %>
                                                      </h2>
                                                      <% if (result.kind==='text' ) { %>
                                                        <pre
                                                          class="bg-white border rounded-3 p-3 mb-0 text-wrap"><%= result.content %></pre>
                                                        <% } else if (result.kind==='file' ) { %>
                                                          <div
                                                            class="alert alert-success border-0 shadow-sm mb-3 d-flex align-items-center gap-2"
                                                            role="alert">
                                                            <span style="font-size: 1.3rem;">✅</span>
