<% layout('layouts/main') -%>

<!-- Hero Section -->
<section class="bg-white border-bottom py-5 py-lg-6">
  <div class="container text-center">
    <div class="row justify-content-center">
      <div class="col-lg-8 col-xl-7">
        <p class="text-uppercase small fw-semibold text-primary mb-3">RaiseTool Utility Hub</p>
        <h1 class="display-4 fw-bold text-dark lh-sm mb-3">Professional Online Tools for Smarter Workflows</h1>
        <p class="lead text-secondary mb-4">Fast, secure, anonymous, and entirely free. Optimize PDFs, resize images, decode developer tokens, and convert units instantly on the server side without user accounts.</p>
        
        <!-- Live Search Bar -->
        <div class="position-relative mx-auto mb-4" style="max-width: 550px;">
          <input type="text" id="toolSearch" class="form-control form-control-lg border shadow-sm px-4" placeholder="Search 50+ tools (e.g. Merge PDF, QR Generator)..." style="border-radius: 50px;">
          <div id="searchResults" class="position-absolute w-100 bg-white border rounded shadow-lg text-start d-none mt-2 z-3" style="max-height: 300px; overflow-y: auto;"></div>
        </div>

        <div class="d-flex justify-content-center gap-3">
          <a href="/workspace" class="btn btn-primary btn-lg px-4">Open My Workspace</a>
          <a href="#categories" class="btn btn-outline-secondary btn-lg px-4">Browse Categories</a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Featured & Popular Tools Section -->
<section class="container py-5">
  <div class="row mb-4">
    <div class="col-12">
      <h2 class="h4 fw-bold text-dark">Featured & Popular Utilities</h2>
      <p class="text-secondary small">Access our most frequently used tools directly.</p>
    </div>
  </div>
  <div class="row g-3">
    <% const featured = [
         { slug: 'merge-pdf', name: 'Merge PDF', desc: 'Combine multiple PDF documents into a single file.', cat: 'PDF' },
         { slug: 'compress-image', name: 'Compress Image', desc: 'Reduce image file sizes without compromising quality.', cat: 'Image' },
         { slug: 'json-formatter', name: 'JSON Formatter', desc: 'Format and beautify raw JSON string inputs.', cat: 'Developer' },
         { slug: 'qr-generator', name: 'QR Generator', desc: 'Generate customized QR code vectors instantly.', cat: 'Utility' }
       ]; %>
    <% featured.forEach((tool) => { %>
      <div class="col-sm-6 col-lg-3">
        <div class="card h-100 shadow-sm border-0">
          <div class="card-body p-4 d-flex flex-column justify-content-between">
            <div>
              <span class="badge bg-light text-primary border mb-3"><%= tool.cat %></span>
              <h3 class="h6 fw-semibold text-dark mb-2"><%= tool.name %></h3>
              <p class="text-secondary small mb-4"><%= tool.desc %></p>
            </div>
            <a href="/tools/<%= tool.slug %>" class="btn btn-outline-primary btn-sm w-100 mt-auto">Use Tool</a>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
</section>

<!-- Tool Categories Section -->
<section id="categories" class="bg-light border-top border-bottom py-5 py-lg-6">
  <div class="container">
    <div class="row mb-5 text-center justify-content-center">
      <div class="col-lg-6">
        <h2 class="h3 fw-bold text-dark mb-3">Explore by Category</h2>
        <p class="text-secondary">Fully client-server isolated tools optimized for maximum safety and performance.</p>
      </div>
    </div>

    <div class="row g-4">
      <% toolCatalog.forEach((category) => { %>
        <div class="col-md-6 col-lg-4 col-xl-3">
          <div class="card h-100 shadow-sm border-0">
            <div class="card-body p-4 d-flex flex-column justify-content-between">
              <div>
                <h3 class="h5 fw-bold text-dark mb-2"><%= category.title %></h3>
                <p class="text-secondary small mb-4"><%= category.description %></p>
              </div>
              <a href="/categories/<%= category.key %>" class="btn btn-link text-decoration-none text-primary fw-medium p-0 text-start">View all <%= category.tools.length %> tools &rarr;</a>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- Statistics Section -->
<section class="container py-5 py-lg-6">
  <div class="row g-4 justify-content-center text-center">
    <div class="col-6 col-md-3">
      <div class="p-3">
        <div class="display-6 fw-bold text-primary">60+</div>
        <div class="text-secondary small fw-medium mt-1">Total Web Tools</div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="p-3">
        <div class="display-6 fw-bold text-primary">100%</div>
        <div class="text-secondary small fw-medium mt-1">Anonymous Sessions</div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="p-3">
        <div class="display-6 fw-bold text-primary">10 Min</div>
        <div class="text-secondary small fw-medium mt-1">Automatic File Expiry</div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="p-3">
        <div class="display-6 fw-bold text-primary">Sub-Second</div>
        <div class="text-secondary small fw-medium mt-1">Processing Time</div>
      </div>
    </div>
  </div>
</section>

<!-- Benefits Section -->
<section class="bg-light border-top border-bottom py-5 py-lg-6">
  <div class="container">
    <div class="row mb-5 text-center justify-content-center">
      <div class="col-lg-6">
        <h2 class="h3 fw-bold text-dark mb-3">Designed for Privacy & Speed</h2>
        <p class="text-secondary">Why developers, students, and professionals trust our online toolset.</p>
      </div>
    </div>

    <div class="row g-4">
      <div class="col-md-4">
        <div class="p-4 bg-white rounded-3 shadow-sm h-100">
          <h3 class="h6 fw-bold text-dark mb-2">No Registration Required</h3>
          <p class="text-secondary small mb-0">Get instant access to all tools. No logins, passwords, or emails. We protect your identity through temporary tokens.</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="p-4 bg-white rounded-3 shadow-sm h-100">
          <h3 class="h6 fw-bold text-dark mb-2">Automatic File Cleanup</h3>
          <p class="text-secondary small mb-0">Files are kept strictly private and secure. All uploads and generated files are automatically deleted after 10 minutes.</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="p-4 bg-white rounded-3 shadow-sm h-100">
          <h3 class="h6 fw-bold text-dark mb-2">Server-Side Processing</h3>
          <p class="text-secondary small mb-0">Heavy operations (like video encoding or PDF merging) happen on our scalable backend, keeping your machine running cool.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- FAQ Section -->
<section class="container py-5 py-lg-6">
  <div class="row mb-5 text-center justify-content-center">
    <div class="col-lg-6">
      <h2 class="h3 fw-bold text-dark mb-2">Frequently Asked Questions</h2>
      <p class="text-secondary">Everything you need to know about RaiseTool.</p>
    </div>
  </div>

  <div class="row justify-content-center">
    <div class="col-lg-8">
      <div class="accordion" id="faqAccordion">
        <div class="accordion-item border-0 shadow-sm mb-3">
          <h2 class="accordion-header" id="faqOne">
            <button class="accordion-button fw-semibold text-dark bg-white" type="button" data-bs-toggle="collapse" data-bs-target="#collapseOne" aria-expanded="true" aria-controls="collapseOne">
              Are my files safe?
            </button>
          </h2>
          <div id="collapseOne" class="accordion-collapse collapse show" aria-labelledby="faqOne" data-bs-parent="#faqAccordion">
            <div class="accordion-body text-secondary small bg-white pt-0">
              Yes, absolutely. We do not inspect, share, or store your files permanently. All uploaded files, processed assets, and system references are completely deleted after 10 minutes of session inactivity.
            </div>
          </div>
        </div>
        <div class="accordion-item border-0 shadow-sm mb-3">
          <h2 class="accordion-header" id="faqTwo">
            <button class="accordion-button collapsed fw-semibold text-dark bg-white" type="button" data-bs-toggle="collapse" data-bs-target="#collapseTwo" aria-expanded="false" aria-controls="collapseTwo">
              Is there a file size limit?
            </button>
          </h2>
          <div id="collapseTwo" class="accordion-collapse collapse" aria-labelledby="faqTwo" data-bs-parent="#faqAccordion">
            <div class="accordion-body text-secondary small bg-white pt-0">
              To prevent server abuse and ensure fast response times for all users, file uploads are restricted to a maximum of 1MB per file on standard tools, and safe thresholds for media converters.
            </div>
          </div>
        </div>
        <div class="accordion-item border-0 shadow-sm mb-3">
          <h2 class="accordion-header" id="faqThree">
            <button class="accordion-button collapsed fw-semibold text-dark bg-white" type="button" data-bs-toggle="collapse" data-bs-target="#collapseThree" aria-expanded="false" aria-controls="collapseThree">
              Do I have to pay to use these tools?
            </button>
          </h2>
          <div id="collapseThree" class="accordion-collapse collapse" aria-labelledby="faqThree" data-bs-parent="#faqAccordion">
            <div class="accordion-body text-secondary small bg-white pt-0">
              No, all tools on RaiseTool are completely free to use. There are no hidden fees, paid tiers, or account registrations.
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Tools data catalog for client-side search -->
<script id="tools-data" type="application/json">
  <%- JSON.stringify(tools.map(t => ({ slug: t.slug, name: t.name, category: t.categoryTitle }))) %>
</script>

<!-- Client-side script for Live Search -->
<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Parse the tools array from the JSON script block
    const allTools = JSON.parse(document.getElementById('tools-data').textContent);
    
    const searchInput = document.getElementById('toolSearch');
    const searchResults = document.getElementById('searchResults');

    if (searchInput && searchResults) {
      searchInput.addEventListener('input', (e) => {
        const query = e.target.value.toLowerCase().trim();
        
        if (!query) {
          searchResults.innerHTML = '';
          searchResults.classList.add('d-none');
          return;
        }

        const filtered = allTools.filter(t => t.name.toLowerCase().includes(query) || t.category.toLowerCase().includes(query));

        if (filtered.length === 0) {
          searchResults.innerHTML = '<div class="p-3 text-secondary small">No tools matched your search.</div>';
        } else {
          let html = '<div class="list-group list-group-flush">';
          filtered.forEach(t => {
            html += `
              <a href="/tools/${t.slug}" class="list-group-item list-group-item-action py-3">
                <div class="d-flex justify-content-between align-items-center">
                  <div class="fw-semibold text-dark small">${t.name}</div>
                  <span class="badge bg-light text-primary border small font-monospace">${t.category}</span>
                </div>
              </a>
            `;
          });
          html += '</div>';
          searchResults.innerHTML = html;
        }
        
        searchResults.classList.remove('d-none');
      });

      // Close search results dropdown when clicking outside
      document.addEventListener('click', (e) => {
        if (!searchInput.contains(e.target) && !searchResults.contains(e.target)) {
          searchResults.classList.add('d-none');
        }
      });
    }
  });
</script>
