<% layout('layouts/main') -%>
<section class="bg-white border-bottom">
  <div class="container py-5 py-lg-6">
    <div class="row align-items-center g-4">
      <div class="col-lg-7">
        <p class="text-uppercase small fw-semibold text-primary mb-2">ToolNest</p>
        <h1 class="display-5 fw-semibold lh-sm text-dark">A professional utility workspace for document, media, developer, and business tasks.</h1>
        <p class="lead text-secondary mt-4">Fast, secure, anonymous, and designed for daily operations without exposing admin or internal system details.</p>
        <div class="d-flex flex-wrap gap-2 mt-4">
          <a href="/workspace" class="btn btn-primary btn-lg">Open My Workspace</a>
          <a href="#tools" class="btn btn-outline-primary btn-lg">Browse Tools</a>
        </div>
      </div>
      <div class="col-lg-5">
        <div class="card shadow-sm border-0">
          <div class="card-body p-4 p-lg-5">
            <div class="text-secondary small text-uppercase fw-semibold">Workspace</div>
            <div class="mt-3 d-grid gap-3">
              <div class="p-3 bg-light rounded-3 border">
                <div class="small text-secondary">Anonymous access</div>
                <div class="fw-semibold">Signed workspace token</div>
              </div>
              <div class="p-3 bg-light rounded-3 border">
                <div class="small text-secondary">Cleanup</div>
                <div class="fw-semibold">Auto-removal after 10 minutes</div>
              </div>
              <div class="p-3 bg-light rounded-3 border">
                <div class="small text-secondary">Security</div>
                <div class="fw-semibold">Sanitized, rate-limited, server-side</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section id="tools" class="container py-5 py-lg-6">
  <div class="row g-4">
    <% toolCatalog.forEach((category) => { %>
      <div class="col-12">
        <div class="card shadow-sm border-0">
          <div class="card-body p-4 p-lg-5">
            <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-end gap-2">
              <div>
                <h2 class="h3 fw-semibold mb-2"><%= category.title %></h2>
                <p class="text-secondary mb-0"><%= category.description %></p>
              </div>
            </div>
            <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-3 mt-2">
              <% category.tools.forEach((tool) => { %>
                <div class="col">
                  <a href="/tools/<%= tool.slug %>" class="btn btn-light border w-100 text-start py-3"><%= tool.name %></a>
                </div>
              <% }) %>
            </div>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
</section>
