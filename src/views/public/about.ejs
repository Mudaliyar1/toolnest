<% layout('layouts/main') -%>
<section class="container py-5">
  <div class="row align-items-center g-5">
    <div class="col-lg-6">
      <h1 class="display-6 fw-semibold text-dark mb-4">About ToolNest</h1>
      <p class="lead text-secondary mb-3">ToolNest is a high-availability, professional utility platform built with node, express, mongodb, and styled with vanilla Bootstrap 5.</p>
      <p class="text-secondary mb-4">Our objective is to deliver quick, anonymous, and premium tools for document management, image optimization, developer conversions, student calculations, and business auditing. We prioritize maximum privacy and delete all uploaded and processed files automatically after 10 minutes.</p>
      <a href="/workspace" class="btn btn-primary">Open My Workspace</a>
    </div>
    <div class="col-lg-6">
      <div class="card bg-light border border-light shadow-sm">
        <div class="card-body p-4 p-lg-5">
          <h2 class="h5 fw-semibold text-dark mb-3">Core Pillars</h2>
          <div class="vstack gap-3">
            <div class="d-flex align-items-start gap-3">
              <div class="bg-white border rounded p-2 text-primary fw-bold">01</div>
              <div>
                <h3 class="h6 fw-semibold mb-1 text-dark">Strict Anonymity</h3>
                <p class="text-secondary small mb-0">No login, no IP tracking. Sessions are stored as signed, encrypted secure tokens.</p>
              </div>
            </div>
            <div class="d-flex align-items-start gap-3">
              <div class="bg-white border rounded p-2 text-primary fw-bold">02</div>
              <div>
                <h3 class="h6 fw-semibold mb-1 text-dark">Auto Cleanup</h3>
                <p class="text-secondary small mb-0">All workspace assets are automatically deleted from server memory and filesystems within 10 minutes.</p>
              </div>
            </div>
            <div class="d-flex align-items-start gap-3">
              <div class="bg-white border rounded p-2 text-primary fw-bold">03</div>
              <div>
                <h3 class="h6 fw-semibold mb-1 text-dark">Production Grade Security</h3>
                <p class="text-secondary small mb-0">Engineered with rate limiting, Slow Down middleware, CSRF tokens, XSS protection, and Helmet CSP settings.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
