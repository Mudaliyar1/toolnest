<% layout('layouts/main') -%>
<%
  const durationToMs = (val, unit) => {
    const v = Number(val) || 0;
    if (unit === 'seconds') return v * 1000;
    if (unit === 'hours') return v * 60 * 60 * 1000;
    return v * 60 * 1000;
  };
  const downloadRetentionMs = durationToMs(systemSettings.downloadRetentionValue || 2, systemSettings.downloadRetentionUnit || 'minutes');
%>
<section class="container py-5 py-lg-6" id="workspace-container" data-download-retention-ms="<%= downloadRetentionMs %>" data-server-now="<%= new Date().toISOString() %>">
  <div class="card border-0 shadow-sm">
    <div class="card-body p-4 p-lg-5">
      <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-end gap-3 mb-4">
        <div>
          <p class="text-uppercase small fw-bold text-primary mb-2" style="letter-spacing: 0.1em;">Anonymous workspace</p>
          <h1 class="display-6 fw-bold text-dark mb-2" style="letter-spacing: -0.02em;">My Workspace</h1>
          <p class="text-secondary mb-0">Temporary anonymous workspace for uploads, processed files, and cleanup tracking.</p>
        </div>
      </div>

      <div class="row g-4 mb-5">
        <div class="col-md-4">
          <div class="p-3 bg-light border-0 shadow-sm rounded-3 h-100" style="border: 1px solid rgba(226, 232, 240, 0.6) !important;">
            <div class="small text-secondary mb-1">Workspace ID</div>
            <div class="fw-bold text-break text-dark font-monospace"><%= workspace ? workspace.workspaceId : 'Pending' %></div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="p-3 bg-light border-0 shadow-sm rounded-3 h-100" style="border: 1px solid rgba(226, 232, 240, 0.6) !important;">
            <div class="small text-secondary mb-1">Remaining Time</div>
            <div id="countdown-timer" class="fw-bold text-primary fs-5" data-expires="<%= workspace ? workspace.expiresAt : '' %>">
              <%= workspace ? `${workspace.remainingMinutes} min` : 'Pending' %>
            </div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="p-3 bg-light border-0 shadow-sm rounded-3 h-100" style="border: 1px solid rgba(226, 232, 240, 0.6) !important;">
            <div class="small text-secondary mb-1">Files</div>
            <div class="fw-bold text-dark fs-5"><%= (files.uploaded || []).length + (files.processed || []).length %></div>
          </div>
        </div>
      </div>

      <div class="row g-4 mt-1">
        <div class="col-lg-6">
          <h2 class="h5 fw-bold text-dark mb-3">Uploaded Files</h2>
          <div class="d-grid gap-3">
            <% if ((files.uploaded || []).length === 0) { %>
              <div class="text-center p-4 border border-dashed rounded-3 text-secondary small bg-light">
                No files uploaded yet. Run a tool to upload files here.
              </div>
            <% } %>
            <% (files.uploaded || []).forEach((file) => { %>
              <div class="border-0 shadow-sm p-3 bg-white file-card rounded-3" style="border: 1px solid rgba(226, 232, 240, 0.6) !important;">
                <div class="d-flex justify-content-between align-items-start gap-2">
                  <div>
                    <div class="fw-bold text-dark text-break"><%= file.processedName %></div>
                    <div class="small text-secondary mt-1"><%= file.fileType %> &middot; <%= file.fileSize %> bytes &middot; <span class="file-local-time" data-time="<%= file.uploadTime.toISOString() %>"></span></div>
                    <div class="file-countdown-timer small text-warning fw-semibold mt-2" data-file-id="<%= file._id %>" data-expires="<%= file.expireTime %>">Expires in: --:--</div>
                  </div>
                  <form method="post" action="/workspace/files/<%= file._id %>/delete">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button type="submit" class="btn btn-outline-danger btn-sm px-3">Delete</button>
                  </form>
                </div>
              </div>
            <% }) %>
          </div>
        </div>

        <div class="col-lg-6">
          <h2 class="h5 fw-bold text-dark mb-3">Processed Files</h2>
          <div class="d-grid gap-3">
            <% if ((files.processed || []).length === 0) { %>
              <div class="text-center p-4 border border-dashed rounded-3 text-secondary small bg-light">
                No files processed yet. Execute a tool to see output files.
              </div>
            <% } %>
            <% (files.processed || []).forEach((file) => { %>
              <div class="border-0 shadow-sm p-3 bg-white file-card rounded-3" style="border: 1px solid rgba(226, 232, 240, 0.6) !important;">
                <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2">
                  <div>
                    <div class="fw-bold text-dark text-break"><%= file.processedName %></div>
                    <div class="small text-secondary mt-1"><%= file.fileType %> &middot; <%= file.fileSize %> bytes &middot; <span class="file-local-time" data-time="<%= file.uploadTime.toISOString() %>"></span></div>
                    <div class="file-countdown-timer small text-warning fw-semibold mt-2" data-file-id="<%= file._id %>" data-expires="<%= file.expireTime %>">Expires in: --:--</div>
                  </div>
                  <div class="d-flex gap-2">
                    <a href="/workspace/files/<%= file._id %>/download" class="btn btn-outline-primary btn-sm px-3 download-btn" data-file-id="<%= file._id %>" download="<%= file.processedName %>">Download</a>
                    <form method="post" action="/workspace/files/<%= file._id %>/delete">
                      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                      <button type="submit" class="btn btn-outline-danger btn-sm px-3">Delete</button>
                    </form>
                  </div>
                </div>
              </div>
            <% }) %>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script src="/js/workspace.js" defer></script>
